{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lbg.local/schemas/mmmorpg-ws/1/entity.snapshot.schema.json",
  "title": "MMMORPG WS v1 — Entity snapshot",
  "type": "object",
  "required": ["id", "kind", "name", "x", "y", "z", "vx", "vy", "vz"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["player", "npc"] },
    "name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "x": { "type": "number" },
    "y": { "type": "number" },
    "z": { "type": "number" },
    "vx": { "type": "number" },
    "vy": { "type": "number" },
    "vz": { "type": "number" },
    "world_state": {
      "type": "object",
      "properties": {
        "reputation": { "type": "integer" },
        "gauges": {
          "type": "object",
          "properties": {
            "hunger": { "type": "number", "minimum": 0, "maximum": 1 },
            "thirst": { "type": "number", "minimum": 0, "maximum": 1 },
            "fatigue": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": true
        },
        "flags": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

