{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lbg.local/schemas/mmmorpg-ws/1/server.world_tick.schema.json",
  "title": "MMMORPG WS v1 — server world_tick",
  "type": "object",
  "required": ["proto", "type", "world_time_s", "day_fraction", "entities"],
  "properties": {
    "proto": { "type": "string", "const": "mmmorpg-ws/1" },
    "type": { "type": "string", "const": "world_tick" },
    "world_time_s": { "type": "number" },
    "day_fraction": { "type": "number" },
    "entities": {
      "type": "array",
      "items": { "$ref": "./entity.snapshot.schema.json" }
    },
    "npc_reply": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}

