# Desktop (hybride) — config hot-reload (Agent_IA Windows)
# Fichier réel attendu sur le poste : `C:\Agent_IA\desktop.env`
#
# ⚠️ Ne pas mettre de secret ici si ce repo est publié.

LBG_DESKTOP_DRY_RUN=1

# Allowlist URL (recommandé : domaines/hosts)
LBG_DESKTOP_URL_ALLOWLIST=
LBG_DESKTOP_URL_HOST_ALLOWLIST=google.com,example.org

# notepad_append : répertoires parents autorisés
LBG_DESKTOP_FILE_ALLOWLIST_DIRS=C:\Users\Public

# Éditeur (après écriture) : notepad | notepad++ | word | default
LBG_DESKTOP_EDITOR=notepad++

# Audit (optionnel)
LBG_DESKTOP_AUDIT_LOG_PATH=C:\Agent_IA\desktop_audit.jsonl
LBG_DESKTOP_AUDIT_STDOUT=1

# (optionnel) exécution réelle protégée
# LBG_DESKTOP_APPROVAL_TOKEN=CHANGE-MOI

# Apps génériques (open_app)
LBG_DESKTOP_APP_ALLOWLIST=notepadpp,word
LBG_DESKTOP_APP_MAP_JSON={"notepadpp":["notepad++.exe"],"word":["winword.exe"]}

