# Desktop (hybride) — config hot-reload (Agent_IA Windows)
# Copier vers `desktop.env` (même dossier que `main.py`).
#
# L’agent relit automatiquement ce fichier quand il change (pas besoin de relancer uvicorn).

# Mode sécurité : dry-run par défaut
LBG_DESKTOP_DRY_RUN=1

# Computer Use (vision + souris/clavier) — désactivé par défaut
LBG_DESKTOP_COMPUTER_USE_ENABLED=0

# Observation : si vide, suit la présence d’un approval token ; sinon 0/1 force.
# Recommandé : 1 si tu actives les captures (confidentialité).
LBG_DESKTOP_OBSERVE_REQUIRES_APPROVAL=1

# Screenshots (observe_screen)
LBG_DESKTOP_SCREENSHOT_DIR=C:\Agent_IA\screenshots
# return: path | base64 | none
LBG_DESKTOP_SCREENSHOT_RETURN=path
LBG_DESKTOP_SCREENSHOT_MAX_WIDTH=1280
LBG_DESKTOP_SCREENSHOT_FORMAT=jpeg
LBG_DESKTOP_SCREENSHOT_JPEG_QUALITY=65

# type_text : limite dure en caractères
LBG_DESKTOP_TYPE_MAX_CHARS=400

# run_steps : limites (sécurité + latence)
LBG_DESKTOP_RUN_STEPS_MAX=12
LBG_DESKTOP_RUN_STEPS_TIMEOUT_MS=30000

# ComfyUI (API locale) — désactivé par défaut
LBG_DESKTOP_COMFYUI_ENABLED=0
LBG_COMFYUI_BASE_URL=http://127.0.0.1:8188
LBG_COMFYUI_TIMEOUT_S=120
LBG_COMFYUI_DOWNLOAD_DIR=C:\Agent_IA\comfyui_downloads

# Allowlist URL (2 modes)
# - strict (URLs exactes) :
# LBG_DESKTOP_URL_ALLOWLIST=https://example.org,https://www.google.com
LBG_DESKTOP_URL_ALLOWLIST=

# - recommandé : domaines/hosts (google.com couvre www.google.com, docs.google.com, etc.)
LBG_DESKTOP_URL_HOST_ALLOWLIST=google.com,example.org

# notepad_append : répertoires parents autorisés
LBG_DESKTOP_FILE_ALLOWLIST_DIRS=C:\Users\Public

# Éditeur (après écriture) : notepad | notepad++ | word | default
LBG_DESKTOP_EDITOR=notepad++
# (optionnel) chemins absolus si pas dans PATH
# LBG_DESKTOP_NOTEPADPP_PATH=C:\Program Files\Notepad++\notepad++.exe
# LBG_DESKTOP_WORD_PATH=C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE

# (optionnel) exécution réelle protégée
# LBG_DESKTOP_APPROVAL_TOKEN=CHANGE-MOI

# Audit (optionnel)
LBG_DESKTOP_AUDIT_LOG_PATH=C:\Agent_IA\desktop_audit.jsonl
LBG_DESKTOP_AUDIT_STDOUT=1

# Apps génériques (open_app)
# - allowlist d’ids logiques
LBG_DESKTOP_APP_ALLOWLIST=notepadpp,word
# - mapping id -> commande (string ou liste)
LBG_DESKTOP_APP_MAP_JSON={"notepadpp":["notepad++.exe"],"word":["winword.exe"]}

# Apprentissage contrôlé (optionnel) : quand `open_app` échoue, l’agent peut résoudre le chemin et
# persister la règle dans `desktop.env` (nécessite `learn:true` dans l’action).
LBG_DESKTOP_LEARN_ENABLED=0
# (optionnel) limiter aux ids listés (si vide : autorise tous les ids envoyés quand learn est activé)
LBG_DESKTOP_LEARN_APP_ALLOWLIST=vlc,notepadpp,word

