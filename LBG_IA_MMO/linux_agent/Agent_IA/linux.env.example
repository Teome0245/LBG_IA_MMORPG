# Agent_IA Linux — config hot-reload
# Copier vers `linux.env`.

LBG_LINUX_DRY_RUN=1

# URL allowlist (2 modes)
LBG_LINUX_URL_ALLOWLIST=
LBG_LINUX_URL_HOST_ALLOWLIST=example.org,google.com

# Fichiers autorisés
LBG_LINUX_FILE_ALLOWLIST_DIRS=/tmp,/var/tmp

# Audit
LBG_LINUX_AUDIT_LOG_PATH=/var/log/lbg/linux_agent_audit.jsonl
LBG_LINUX_AUDIT_STDOUT=1

# Apps (open_app)
LBG_LINUX_APP_ALLOWLIST=htop
LBG_LINUX_APP_MAP_JSON={"htop":["/usr/bin/htop"]}

# Apprentissage contrôlé (optionnel)
LBG_LINUX_LEARN_ENABLED=0
LBG_LINUX_LEARN_APP_ALLOWLIST=htop

# (optionnel) exécution réelle protégée
# LBG_LINUX_APPROVAL_TOKEN=CHANGE-MOI

