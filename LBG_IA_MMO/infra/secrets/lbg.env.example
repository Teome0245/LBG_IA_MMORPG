# Copier vers lbg.env : cp infra/secrets/lbg.env.example infra/secrets/lbg.env
# Maintenance : même structure et ordre que infra/secrets/lbg.env (local) — à mettre à jour
# dans le même changement ; jamais de secrets réels ici. Voir docs/plan_de_route.md priorité 0.
# =============================================================================

# =============================================================================
# LBG_IA_MMO — Services principaux
# =============================================================================
# Topologie LAN (plan / docs/fusion_env_lan.md) :
#   140 = backend + orchestrateur + agents | 245 = mmo_server (8050) + mmmorpg WS (7733) | 110 = Ollama
# Même fichier sur les 3 VM : IP LAN réelles pour le core (pas 127.0.0.1 — sinon 245/110 visent la mauvaise machine).

LBG_ORCHESTRATOR_URL="http://192.168.0.140:8010"
LBG_AGENT_DIALOGUE_URL="http://192.168.0.140:8020"
LBG_AGENT_QUESTS_URL="http://192.168.0.140:8030"
LBG_AGENT_COMBAT_URL="http://192.168.0.140:8040"
# Chef de projet (intent project_pm) — systemd lbg-agent-pm port 8055 sur core
LBG_AGENT_PM_URL="http://192.168.0.140:8055"
# Desktop (hybride) — worker HTTP sur machine Windows (ex. 8060)
# LBG_AGENT_DESKTOP_URL="http://192.168.0.50:8060"
LBG_CORS_ORIGINS="http://192.168.0.110,http://192.168.0.110:8080"

# MMO server — choisis l’un des deux (local ou LAN)
# LBG_MMO_SERVER_URL="http://127.0.0.1:8050"
LBG_MMO_SERVER_URL="http://192.168.0.245:8050"
# Écriture interne sur mmo_server (optionnel) : si défini, protège
# `POST /internal/v1/npc/{npc_id}/reputation` via `X-LBG-Service-Token`.
# Recommandation : utiliser la même valeur que `LBG_PILOT_INTERNAL_TOKEN` (simplifie les smokes + double-write).
# LBG_MMO_INTERNAL_TOKEN="change-moi"
# Persistance / seed (surtout sur la VM 245 où tourne mmo_server — sinon défauts dans le code)
# LBG_MMO_SEED_PATH=
# LBG_MMO_STATE_PATH="/var/lib/lbg/mmo/world_state.json"
# LBG_MMO_SAVE_INTERVAL_S=30
# LBG_MMO_DISABLE_PERSIST=0

# Serveur WebSocket jeu (mmmorpg_server) — systemd lbg-mmmorpg-ws sur 245 ; clients → ws://192.168.0.245:7733
# À activer sur la VM 245 (ou tout fichier poussé vers /etc/lbg-ia-mmo.env pour ce service)
MMMORPG_HOST=0.0.0.0
MMMORPG_PORT=7733
MMMORPG_INTERNAL_HTTP_HOST="0.0.0.0"
MMMORPG_INTERNAL_HTTP_PORT="8773"
MMMORPG_INTERNAL_HTTP_TOKEN="change-moi"
MMMORPG_INTERNAL_HTTP_RL_RPS="5"
MMMORPG_INTERNAL_HTTP_RL_BURST="10"
# Métriques HTTP interne (:8773) — l’unité lbg-mmmorpg-ws fixe MMMORPG_INTERNAL_HTTP_METRICS=0 par défaut.
# MMMORPG_INTERNAL_HTTP_METRICS=1
MMMORPG_STATE_PATH="/var/lib/lbg/mmmorpg/state.json"
MMMORPG_DISABLE_PERSIST=0
LBG_MMMORPG_INTERNAL_HTTP_URL="http://192.168.0.245:8773"
LBG_MMMORPG_INTERNAL_HTTP_TOKEN="change-moi"
# MMMORPG_TICK_RATE_HZ=20
# MMMORPG_MAX_WS_INBOUND_BYTES=65536
# MMMORPG_MOVE_MIN_INTERVAL_S=0.02
#
# Pont jeu → IA (optionnel) : permet au serveur WS d'appeler le backend monorepo (hello → /v1/pilot/route).
MMMORPG_IA_BACKEND_URL="http://192.168.0.140:8000"
MMMORPG_IA_TIMEOUT_S="120"
MMMORPG_IA_BACKEND_PATH="/v1/pilot/internal/route"
MMMORPG_IA_BACKEND_TOKEN="change-moi"
MMMORPG_IA_PLACEHOLDER_ENABLED="1"
MMMORPG_IA_PLACEHOLDER_REPLY="…un instant. (Le PNJ vous regarde, comme s’il réfléchissait.)"

# Durcissement backend (VM 140) — endpoint interne /v1/pilot/internal/route
LBG_PILOT_INTERNAL_TOKEN="change-moi"
LBG_PILOT_INTERNAL_RL_RPS="2"
LBG_PILOT_INTERNAL_RL_BURST="4"

# Observabilité (opt-in) — lu par systemd (lbg-backend, lbg-orchestrator) via /etc/lbg-ia-mmo.env
# Les unités fixent LBG_METRICS_ENABLED=0 par défaut ; ce fichier peut le passer à 1 sur la VM core.
# LBG_METRICS_ENABLED=1
# LBG_METRICS_TOKEN="change-moi"

# =============================================================================
# Réconciliation IA → jeu (commit dialogue) — contrat backend (phase C)
# =============================================================================
# (optionnel) Whitelist config-driven (si non défini : défauts dans backend/services/mmmorpg_commit.py)
# LBG_MMMORPG_COMMIT_ALLOWED_FLAGS="quest_accepted,quest_id,quest_step,mood,rp_tone,reputation_delta"
# (optionnel) Limites best-effort (le serveur jeu revalide aussi)
# LBG_MMMORPG_COMMIT_MAX_FLAGS="16"
# LBG_MMMORPG_COMMIT_MAX_KEY_LEN="64"
# LBG_MMMORPG_COMMIT_MAX_STR_LEN="256"

# Timeouts orchestrateur / agents
LBG_AGENT_DIALOGUE_TIMEOUT="240"
LBG_ORCHESTRATOR_TIMEOUT="240"
LBG_DIALOGUE_LLM_TIMEOUT="240"
LBG_AGENT_COMBAT_TIMEOUT="30"


# =============================================================================
# Dialogue LLM (Agent HTTP :8020)
# =============================================================================
# Défauts dans dialogue_llm.py si rien n’est défini :
#   BASE_URL=http://127.0.0.1:11434/v1
#   MODEL=llama3.2:latest
# Pour forcer le mode stub sans Ollama : LBG_DIALOGUE_LLM_DISABLED=1

# --- Groq (optionnel) ---
# LBG_DIALOGUE_LLM_BASE_URL="https://api.groq.com/openai/v1"
# LBG_DIALOGUE_LLM_MODEL="llama-3.1-8b-instant"
GROQ_MODEL_FAST="llama-3.1-8b-instant"
GROQ_MODEL_BALANCED="llama-3.1-8b-instant"
GROQ_MODEL_SMART="llama-3.1-8b-instant"

# --- Ollama (LAN) ---
LBG_DIALOGUE_LLM_BASE_URL="http://192.168.0.110:11434/v1"
LBG_DIALOGUE_LLM_MODEL="phi4-mini:latest"
LBG_DIALOGUE_LLM_MAX_TOKENS="32"
LBG_DIALOGUE_LLM_TEMPERATURE="0.2"
LBG_DIALOGUE_STRICT_SHORT="1"
LBG_DIALOGUE_MAX_SENTENCES="2"
LBG_DIALOGUE_MAX_WORDS="25"
LBG_DIALOGUE_LLM_MAX_HISTORY="8"
LBG_DIALOGUE_CACHE_TTL_S="120"
LBG_DIALOGUE_CACHE_MAX_ITEMS="512"
LBG_DIALOGUE_CACHE_CONTEXT_KEYS="world_npc_id,quest_state,encounter_state,world_flags"
LBG_DIALOGUE_ADMIN_TOKEN="change-moi"

# --- OpenAI (optionnel) ---
# LBG_DIALOGUE_LLM_BASE_URL="https://api.openai.com/v1"
# LBG_DIALOGUE_LLM_API_KEY=""
# LBG_DIALOGUE_LLM_MODEL="gpt-4o-mini"


# =============================================================================
# Agents HTTP tiers (LBG_IA / orchestrateur historique)
# — AGENT_LINUX_MMMORPG_URL :6000 n’est pas le WebSocket jeu (7733 → mmmorpg_server)
# =============================================================================
AGENT_DEVOPS_VM_URL="http://192.168.0.110:18001"
AGENT_WINDOWS_URL="http://192.168.0.10:5005"
AGENT_WINDOWS_SRV_AD_URL="http://192.168.0.100:5005"
AGENT_LINUX_MMMORPG_URL="http://192.168.0.245:6000"
AGENT_LINUX_IA_URL="http://192.168.0.110:6000"
AGENT_LINUX_MAIL_URL="http://192.168.0.90:6000"

OLLAMA_BASE_URL="http://192.168.0.110:11434"

# =============================================================================
# DevOps (sonde — agents/README.md) — healthz 140/245 si besoin
# =============================================================================
# LBG_DEVOPS_HTTP_ALLOWLIST="http://192.168.0.140:8010/healthz,http://192.168.0.140:8000/healthz,http://192.168.0.245:8050/healthz"
# Unités systemd autorisées pour devops_action kind=systemd_is_active (virgules ; vide = désactivé).
# LBG_DEVOPS_SYSTEMD_UNIT_ALLOWLIST="lbg-agent-dialogue.service,lbg-agent-quests.service,lbg-agent-combat.service,lbg-orchestrator.service,lbg-backend.service,lbg-mmo-server.service,lbg-mmmorpg-ws.service"
# Unités systemd autorisées pour devops_action kind=systemd_restart (virgules ; vide = désactivé).
# LBG_DEVOPS_SYSTEMD_RESTART_ALLOWLIST="lbg-backend.service,lbg-orchestrator.service"
# (optionnel) Quota : tentatives réelles max par fenêtre glissante (secondes), par processus agent.
# LBG_DEVOPS_SYSTEMD_RESTART_MAX_PER_WINDOW="8"
# LBG_DEVOPS_SYSTEMD_RESTART_WINDOW_S="3600"
# (optionnel) Fenêtre UTC : si défini, restart réel uniquement quand l’heure UTC est dans HH:MM-HH:MM (traverse minuit si début > fin).
# LBG_DEVOPS_SYSTEMD_RESTART_MAINTENANCE_UTC="02:00-04:30"
# (optionnel) Selfcheck DevOps : URLs healthz explicites ; unités systemd explicites (sinon défaut backend+orchestrator dans l’allowlist)
# LBG_DEVOPS_SELFCHECK_HTTP="http://192.168.0.140:8010/healthz,http://192.168.0.140:8000/healthz"
# LBG_DEVOPS_SELFCHECK_SYSTEMD="lbg-backend.service,lbg-orchestrator.service"
# LBG_DEVOPS_LOG_ALLOWLIST="/var/log/syslog"
# LBG_DEVOPS_DRY_RUN="1"
# LBG_DEVOPS_APPROVAL_TOKEN="change-moi"
# LBG_DEVOPS_AUDIT_LOG_PATH="/var/log/lbg/devops_audit.jsonl"
# LBG_DEVOPS_AUDIT_STDOUT="1"

# =============================================================================
# Multi‑LLM providers (DeepSeek, Mistral, Gemini, DeepInfra, HF)
# =============================================================================
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL_CHAT="deepseek-chat"
DEEPSEEK_MODEL_REASONER="deepseek-reasoner"

MISTRAL_API_KEY=""
MISTRAL_BASE_URL="https://api.mistral.ai"
MISTRAL_MODEL_CHAT="open-mistral-nemo"

GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1"
GEMINI_MODEL="gemini-1.5-flash-latest"

DEEPINFRA_BASE_URL="https://api.deepinfra.com/v1/openai"

HF_BASE_URL="https://api-inference.huggingface.co"

# =============================================================================
# Clés API — réservées aux évolutions (orchestrateur, outils, scripts) ;
# non lues par le code minimal actuel sauf si tu branches ces variables.
# =============================================================================

# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# DEEPINFRA_API_KEY=
# HF_API_KEY=
# OPENROUTER_API_KEY=
