[Unit]
Description=LBG MMMORPG WebSocket server (Phase 1)
After=network.target

[Service]
Type=simple
User=lbg
Group=lbg
WorkingDirectory=/opt/LBG_IA_MMO/mmmorpg_server
# HTTP interne (MMMORPG_INTERNAL_HTTP_*) : GET /metrics désactivé par défaut.
# Surcharge : /etc/lbg-ia-mmo.env — MMMORPG_INTERNAL_HTTP_METRICS=1
Environment=MMMORPG_INTERNAL_HTTP_METRICS=0
EnvironmentFile=-/etc/lbg-ia-mmo.env
Environment=PYTHONUNBUFFERED=1
# Ports / bind : MMMORPG_HOST (défaut 0.0.0.0), MMMORPG_PORT (défaut 7733) — voir mmmorpg_server/config.py
ExecStart=/opt/LBG_IA_MMO/.venv/bin/python -m mmmorpg_server
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
