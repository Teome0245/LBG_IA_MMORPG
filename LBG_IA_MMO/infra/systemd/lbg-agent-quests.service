[Unit]
Description=LBG_IA_MMO Quests HTTP agent
After=network.target

[Service]
Type=simple
User=lbg
Group=lbg
WorkingDirectory=/opt/LBG_IA_MMO
# Clés API et LBG_* : poussées avec infra/scripts/push_secrets_vm.sh → /etc/lbg-ia-mmo.env
EnvironmentFile=-/etc/lbg-ia-mmo.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/LBG_IA_MMO/.venv/bin/uvicorn lbg_agents.quests_http_app:app --host 0.0.0.0 --port 8030
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

