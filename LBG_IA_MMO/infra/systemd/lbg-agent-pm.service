[Unit]
Description=LBG_IA_MMO PM (chef de projet) HTTP agent
After=network.target

[Service]
Type=simple
User=lbg
Group=lbg
WorkingDirectory=/opt/LBG_IA_MMO
EnvironmentFile=-/etc/lbg-ia-mmo.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/LBG_IA_MMO/.venv/bin/uvicorn lbg_agents.pm_http_app:app --host 0.0.0.0 --port 8055
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
